[{"id":"tang-libai-001","title":"静夜思","dynasty":"唐","author":"李白","content":["床前明月光，","疑是地上霜。","举头望明月，","低头思故乡。"],"tags":["思乡","五言绝句"],"note":"","appreciation":"以最朴素的语言写最普遍的乡愁，千古绝唱。"},{"id":"tang-libai-002","title":"早发白帝城","dynasty":"唐","author":"李白","content":["朝辞白帝彩云间，","千里江陵一日还。","两岸猿声啼不住，","轻舟已过万重山。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-003","title":"望庐山瀑布","dynasty":"唐","author":"李白","content":["日照香炉生紫烟，","遥看瀑布挂前川。","飞流直下三千尺，","疑是银河落九天。"],"tags":["写景","山水","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-004","title":"黄鹤楼送孟浩然之广陵","dynasty":"唐","author":"李白","content":["故人西辞黄鹤楼，","烟花三月下扬州。","孤帆远影碧空尽，","唯见长江天际流。"],"tags":["送别","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-005","title":"赠汪伦","dynasty":"唐","author":"李白","content":["李白乘舟将欲行，","忽闻岸上踏歌声。","桃花潭水深千尺，","不及汪伦送我情。"],"tags":["友情","送别","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-006","title":"望天门山","dynasty":"唐","author":"李白","content":["天门中断楚江开，","碧水东流至此回。","两岸青山相对出，","孤帆一片日边来。"],"tags":["写景","山水","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-007","title":"独坐敬亭山","dynasty":"唐","author":"李白","content":["众鸟高飞尽，","孤云独去闲。","相看两不厌，","只有敬亭山。"],"tags":["山水","五言绝句"],"note":"","appreciation":""},{"id":"tang-libai-008","title":"秋浦歌","dynasty":"唐","author":"李白","content":["白发三千丈，","缘愁似个长。","不知明镜里，","何处得秋霜。"],"tags":["抒情","五言绝句"],"note":"","appreciation":""},{"id":"tang-libai-009","title":"夜宿山寺","dynasty":"唐","author":"李白","content":["危楼高百尺，","手可摘星辰。","不敢高声语，","恐惊天上人。"],"tags":["写景","五言绝句"],"note":"","appreciation":""},{"id":"tang-libai-010","title":"春夜洛城闻笛","dynasty":"唐","author":"李白","content":["谁家玉笛暗飞声，","散入春风满洛城。","此夜曲中闻折柳，","何人不起故园情。"],"tags":["思乡","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-011","title":"峨眉山月歌","dynasty":"唐","author":"李白","content":["峨眉山月半轮秋，","影入平羌江水流。","夜发清溪向三峡，","思君不见下渝州。"],"tags":["写景","思乡","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-012","title":"客中作","dynasty":"唐","author":"李白","content":["兰陵美酒郁金香，","玉碗盛来琥珀光。","但使主人能醉客，","不知何处是他乡。"],"tags":["羁旅","七言绝句"],"note":"","appreciation":""},{"id":"tang-libai-013","title":"月下独酌","dynasty":"唐","author":"李白","content":["花间一壶酒，","独酌无相亲。","举杯邀明月，","对影成三人。","月既不解饮，","影徒随我身。","暂伴月将影，","行乐须及春。","我歌月徘徊，","我舞影零乱。","醒时同交欢，","醉后各分散。","永结无情游，","相期邈云汉。"],"tags":["抒情","月亮"],"note":"","appreciation":""},{"id":"tang-libai-014","title":"行路难","dynasty":"唐","author":"李白","content":["金樽清酒斗十千，","玉盘珍羞直万钱。","停杯投箸不能食，","拔剑四顾心茫然。","欲渡黄河冰塞川，","将登太行雪满山。","闲来垂钓碧溪上，","忽复乘舟梦日边。","行路难，行路难，","多歧路，今安在？","长风破浪会有时，","直挂云帆济沧海。"],"tags":["抒怀","励志"],"note":"","appreciation":"“长风破浪会有时”是李白式的豪迈自信。"},{"id":"tang-libai-015","title":"将进酒","dynasty":"唐","author":"李白","content":["君不见黄河之水天上来，","奔流到海不复回。","君不见高堂明镜悲白发，","朝如青丝暮成雪。","人生得意须尽欢，","莫使金樽空对月。","天生我材必有用，","千金散尽还复来。","烹羊宰牛且为乐，","会须一饮三百杯。","岑夫子，丹丘生，","将进酒，杯莫停。","与君歌一曲，","请君为我倾耳听。","钟鼓馔玉不足贵，","但愿长醉不愿醒。","古来圣贤皆寂寞，","惟有饮者留其名。","陈王昔时宴平乐，","斗酒十千恣欢谑。","主人何为言少钱，","径须沽取对君酌。","五花马，千金裘，","呼儿将出换美酒，","与尔同销万古愁。"],"tags":["饮酒","抒怀","乐府"],"note":"","appreciation":"气象宏大、情感奔放，是李白浪漫主义诗风的代表作。"},{"id":"tang-dufu-001","title":"春望","dynasty":"唐","author":"杜甫","content":["国破山河在，","城春草木深。","感时花溅泪，","恨别鸟惊心。","烽火连三月，","家书抵万金。","白头搔更短，","浑欲不胜簪。"],"tags":["忧国","五言律诗"],"note":"","appreciation":"触景伤时，字字血泪，沉郁顿挫之至。"},{"id":"tang-dufu-002","title":"绝句","dynasty":"唐","author":"杜甫","content":["两个黄鹂鸣翠柳，","一行白鹭上青天。","窗含西岭千秋雪，","门泊东吴万里船。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-dufu-003","title":"江畔独步寻花","dynasty":"唐","author":"杜甫","content":["黄四娘家花满蹊，","千朵万朵压枝低。","留连戏蝶时时舞，","自在娇莺恰恰啼。"],"tags":["写景","春日","七言绝句"],"note":"","appreciation":""},{"id":"tang-dufu-004","title":"江南逢李龟年","dynasty":"唐","author":"杜甫","content":["岐王宅里寻常见，","崔九堂前几度闻。","正是江南好风景，","落花时节又逢君。"],"tags":["感怀","七言绝句"],"note":"","appreciation":""},{"id":"tang-dufu-005","title":"绝句","dynasty":"唐","author":"杜甫","content":["迟日江山丽，","春风花草香。","泥融飞燕子，","沙暖睡鸳鸯。"],"tags":["写景","五言绝句"],"note":"","appreciation":""},{"id":"tang-dufu-006","title":"八阵图","dynasty":"唐","author":"杜甫","content":["功盖三分国，","名成八阵图。","江流石不转，","遗恨失吞吴。"],"tags":["怀古","五言绝句"],"note":"","appreciation":""},{"id":"tang-dufu-007","title":"望岳","dynasty":"唐","author":"杜甫","content":["岱宗夫如何？","齐鲁青未了。","造化钟神秀，","阴阳割昏晓。","荡胸生曾云，","决眦入归鸟。","会当凌绝顶，","一览众山小。"],"tags":["山水","励志","五言律诗"],"note":"","appreciation":"“会当凌绝顶，一览众山小”尽显青年杜甫的雄心。"},{"id":"tang-dufu-008","title":"春夜喜雨","dynasty":"唐","author":"杜甫","content":["好雨知时节，","当春乃发生。","随风潜入夜，","润物细无声。","野径云俱黑，","江船火独明。","晓看红湿处，","花重锦官城。"],"tags":["写景","春雨","五言律诗"],"note":"","appreciation":""},{"id":"tang-dufu-009","title":"闻官军收河南河北","dynasty":"唐","author":"杜甫","content":["剑外忽传收蓟北，","初闻涕泪满衣裳。","却看妻子愁何在，","漫卷诗书喜欲狂。","白日放歌须纵酒，","青春作伴好还乡。","即从巴峡穿巫峡，","便下襄阳向洛阳。"],"tags":["喜悦","七言律诗"],"note":"","appreciation":"杜甫“生平第一快诗”。"},{"id":"tang-dufu-010","title":"登岳阳楼","dynasty":"唐","author":"杜甫","content":["昔闻洞庭水，","今上岳阳楼。","吴楚东南坼，","乾坤日夜浮。","亲朋无一字，","老病有孤舟。","戎马关山北，","凭轩涕泗流。"],"tags":["怀古","忧国","五言律诗"],"note":"","appreciation":""},{"id":"tang-dufu-011","title":"茅屋为秋风所破歌","dynasty":"唐","author":"杜甫","content":["八月秋高风怒号，","卷我屋上三重茅。","茅飞渡江洒江郊，","高者挂罥长林梢，","下者飘转沉塘坳。","南村群童欺我老无力，","忍能对面为盗贼。","公然抱茅入竹去，","唇焦口燥呼不得，","归来倚杖自叹息。","俄顷风定云墨色，","秋天漠漠向昏黑。","布衾多年冷似铁，","娇儿恶卧踏里裂。","床头屋漏无干处，","雨脚如麻未断绝。","自经丧乱少睡眠，","长夜沾湿何由彻！","安得广厦千万间，","大庇天下寒士俱欢颜，","风雨不动安如山。","呜呼！","何时眼前突兀见此屋，","吾庐独破受冻死亦足！"],"tags":["忧民","叙事","古诗"],"note":"","appreciation":"由自身苦难推及天下寒士，境界崇高。"},{"id":"tang-wangwei-001","title":"相思","dynasty":"唐","author":"王维","content":["红豆生南国，","春来发几枝。","愿君多采撷，","此物最相思。"],"tags":["友情","五言绝句"],"note":"","appreciation":""},{"id":"tang-wangwei-002","title":"鹿柴","dynasty":"唐","author":"王维","content":["空山不见人，","但闻人语响。","返景入深林，","复照青苔上。"],"tags":["山水","五言绝句"],"note":"","appreciation":""},{"id":"tang-wangwei-003","title":"竹里馆","dynasty":"唐","author":"王维","content":["独坐幽篁里，","弹琴复长啸。","深林人不知，","明月来相照。"],"tags":["隐逸","五言绝句"],"note":"","appreciation":""},{"id":"tang-wangwei-004","title":"送元二使安西","dynasty":"唐","author":"王维","content":["渭城朝雨浥轻尘，","客舍青青柳色新。","劝君更尽一杯酒，","西出阳关无故人。"],"tags":["送别","七言绝句"],"note":"","appreciation":""},{"id":"tang-wangwei-005","title":"九月九日忆山东兄弟","dynasty":"唐","author":"王维","content":["独在异乡为异客，","每逢佳节倍思亲。","遥知兄弟登高处，","遍插茱萸少一人。"],"tags":["思乡","七言绝句"],"note":"","appreciation":"“每逢佳节倍思亲”道尽游子之心。"},{"id":"tang-wangwei-006","title":"山居秋暝","dynasty":"唐","author":"王维","content":["空山新雨后，","天气晚来秋。","明月松间照，","清泉石上流。","竹喧归浣女，","莲动下渔舟。","随意春芳歇，","王孙自可留。"],"tags":["山水","五言律诗"],"note":"","appreciation":""},{"id":"tang-wangwei-007","title":"鸟鸣涧","dynasty":"唐","author":"王维","content":["人闲桂花落，","夜静春山空。","月出惊山鸟，","时鸣春涧中。"],"tags":["山水","五言绝句"],"note":"","appreciation":""},{"id":"tang-wangwei-008","title":"使至塞上","dynasty":"唐","author":"王维","content":["单车欲问边，","属国过居延。","征蓬出汉塞，","归雁入胡天。","大漠孤烟直，","长河落日圆。","萧关逢候骑，","都护在燕然。"],"tags":["边塞","写景","五言律诗"],"note":"","appreciation":"“大漠孤烟直，长河落日圆”为千古壮观名句。"},{"id":"tang-menghaoran-001","title":"春晓","dynasty":"唐","author":"孟浩然","content":["春眠不觉晓，","处处闻啼鸟。","夜来风雨声，","花落知多少。"],"tags":["春日","五言绝句"],"note":"","appreciation":"平淡中见深意，千古传诵。"},{"id":"tang-menghaoran-002","title":"宿建德江","dynasty":"唐","author":"孟浩然","content":["移舟泊烟渚，","日暮客愁新。","野旷天低树，","江清月近人。"],"tags":["羁旅","五言绝句"],"note":"","appreciation":""},{"id":"tang-menghaoran-003","title":"过故人庄","dynasty":"唐","author":"孟浩然","content":["故人具鸡黍，","邀我至田家。","绿树村边合，","青山郭外斜。","开轩面场圃，","把酒话桑麻。","待到重阳日，","还来就菊花。"],"tags":["田园","友情","五言律诗"],"note":"","appreciation":""},{"id":"tang-menghaoran-004","title":"望洞庭湖赠张丞相","dynasty":"唐","author":"孟浩然","content":["八月湖水平，","涵虚混太清。","气蒸云梦泽，","波撼岳阳城。","欲济无舟楫，","端居耻圣明。","坐观垂钓者，","徒有羡鱼情。"],"tags":["写景","言志","五言律诗"],"note":"","appreciation":""},{"id":"tang-wangzhihuan-001","title":"登鹳雀楼","dynasty":"唐","author":"王之涣","content":["白日依山尽，","黄河入海流。","欲穷千里目，","更上一层楼。"],"tags":["哲理","五言绝句"],"note":"","appreciation":"“更上一层楼”寓含进取之意，传诵极广。"},{"id":"tang-wangzhihuan-002","title":"凉州词","dynasty":"唐","author":"王之涣","content":["黄河远上白云间，","一片孤城万仞山。","羌笛何须怨杨柳，","春风不度玉门关。"],"tags":["边塞","七言绝句"],"note":"","appreciation":""},{"id":"tang-wangchangling-001","title":"出塞","dynasty":"唐","author":"王昌龄","content":["秦时明月汉时关，","万里长征人未还。","但使龙城飞将在，","不教胡马度阴山。"],"tags":["边塞","七言绝句"],"note":"","appreciation":""},{"id":"tang-wangchangling-002","title":"芙蓉楼送辛渐","dynasty":"唐","author":"王昌龄","content":["寒雨连江夜入吴，","平明送客楚山孤。","洛阳亲友如相问，","一片冰心在玉壶。"],"tags":["送别","七言绝句"],"note":"","appreciation":"“一片冰心在玉壶”喻品格高洁。"},{"id":"tang-gaoshi-001","title":"别董大","dynasty":"唐","author":"高适","content":["千里黄云白日曛，","北风吹雁雪纷纷。","莫愁前路无知己，","天下谁人不识君。"],"tags":["送别","七言绝句"],"note":"","appreciation":""},{"id":"tang-censhen-001","title":"逢入京使","dynasty":"唐","author":"岑参","content":["故园东望路漫漫，","双袖龙钟泪不干。","马上相逢无纸笔，","凭君传语报平安。"],"tags":["思乡","七言绝句"],"note":"","appreciation":""},{"id":"tang-censhen-002","title":"白雪歌送武判官归京","dynasty":"唐","author":"岑参","content":["北风卷地白草折，","胡天八月即飞雪。","忽如一夜春风来，","千树万树梨花开。","散入珠帘湿罗幕，","狐裘不暖锦衾薄。","将军角弓不得控，","都护铁衣冷难着。","瀚海阑干百丈冰，","愁云惨淡万里凝。","中军置酒饮归客，","胡琴琵琶与羌笛。","纷纷暮雪下辕门，","风掣红旗冻不翻。","轮台东门送君去，","去时雪满天山路。","山回路转不见君，","雪上空留马行处。"],"tags":["边塞","送别","古诗"],"note":"","appreciation":"“忽如一夜春风来，千树万树梨花开”以春花喻冬雪，奇绝。"},{"id":"tang-baijuyi-001","title":"赋得古原草送别","dynasty":"唐","author":"白居易","content":["离离原上草，","一岁一枯荣。","野火烧不尽，","春风吹又生。","远芳侵古道，","晴翠接荒城。","又送王孙去，","萋萋满别情。"],"tags":["送别","五言律诗"],"note":"","appreciation":"“野火烧不尽，春风吹又生”喻生命力顽强。"},{"id":"tang-baijuyi-002","title":"忆江南","dynasty":"唐","author":"白居易","content":["江南好，","风景旧曾谙。","日出江花红胜火，","春来江水绿如蓝。","能不忆江南？"],"tags":["写景","词","江南"],"note":"","appreciation":""},{"id":"tang-baijuyi-003","title":"暮江吟","dynasty":"唐","author":"白居易","content":["一道残阳铺水中，","半江瑟瑟半江红。","可怜九月初三夜，","露似真珠月似弓。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-baijuyi-004","title":"池上","dynasty":"唐","author":"白居易","content":["小娃撑小艇，","偷采白莲回。","不解藏踪迹，","浮萍一道开。"],"tags":["童趣","五言绝句"],"note":"","appreciation":""},{"id":"tang-baijuyi-005","title":"问刘十九","dynasty":"唐","author":"白居易","content":["绿蚁新醅酒，","红泥小火炉。","晚来天欲雪，","能饮一杯无？"],"tags":["友情","五言绝句"],"note":"","appreciation":""},{"id":"tang-baijuyi-006","title":"钱塘湖春行","dynasty":"唐","author":"白居易","content":["孤山寺北贾亭西，","水面初平云脚低。","几处早莺争暖树，","谁家新燕啄春泥。","乱花渐欲迷人眼，","浅草才能没马蹄。","最爱湖东行不足，","绿杨阴里白沙堤。"],"tags":["写景","春日","七言律诗"],"note":"","appreciation":""},{"id":"tang-baijuyi-007","title":"大林寺桃花","dynasty":"唐","author":"白居易","content":["人间四月芳菲尽，","山寺桃花始盛开。","长恨春归无觅处，","不知转入此中来。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-lishangyin-001","title":"登乐游原","dynasty":"唐","author":"李商隐","content":["向晚意不适，","驱车登古原。","夕阳无限好，","只是近黄昏。"],"tags":["感怀","五言绝句"],"note":"","appreciation":"“夕阳无限好，只是近黄昏”叹美好之短暂。"},{"id":"tang-lishangyin-002","title":"夜雨寄北","dynasty":"唐","author":"李商隐","content":["君问归期未有期，","巴山夜雨涨秋池。","何当共剪西窗烛，","却话巴山夜雨时。"],"tags":["思乡","七言绝句"],"note":"","appreciation":"时空回环，情致深婉。"},{"id":"tang-lishangyin-003","title":"无题","dynasty":"唐","author":"李商隐","content":["相见时难别亦难，","东风无力百花残。","春蚕到死丝方尽，","蜡炬成灰泪始干。","晓镜但愁云鬓改，","夜吟应觉月光寒。","蓬山此去无多路，","青鸟殷勤为探看。"],"tags":["爱情","七言律诗"],"note":"","appreciation":"“春蚕到死丝方尽，蜡炬成灰泪始干”为至情至性之名句。"},{"id":"tang-lishangyin-004","title":"锦瑟","dynasty":"唐","author":"李商隐","content":["锦瑟无端五十弦，","一弦一柱思华年。","庄生晓梦迷蝴蝶，","望帝春心托杜鹃。","沧海月明珠有泪，","蓝田日暖玉生烟。","此情可待成追忆，","只是当时已惘然。"],"tags":["感怀","七言律诗"],"note":"","appreciation":""},{"id":"tang-lishangyin-005","title":"嫦娥","dynasty":"唐","author":"李商隐","content":["云母屏风烛影深，","长河渐落晓星沉。","嫦娥应悔偷灵药，","碧海青天夜夜心。"],"tags":["抒怀","七言绝句"],"note":"","appreciation":""},{"id":"tang-dumu-001","title":"清明","dynasty":"唐","author":"杜牧","content":["清明时节雨纷纷，","路上行人欲断魂。","借问酒家何处有，","牧童遥指杏花村。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-dumu-002","title":"江南春","dynasty":"唐","author":"杜牧","content":["千里莺啼绿映红，","水村山郭酒旗风。","南朝四百八十寺，","多少楼台烟雨中。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-dumu-003","title":"山行","dynasty":"唐","author":"杜牧","content":["远上寒山石径斜，","白云生处有人家。","停车坐爱枫林晚，","霜叶红于二月花。"],"tags":["写景","秋日","七言绝句"],"note":"","appreciation":"“霜叶红于二月花”写秋色胜春。"},{"id":"tang-dumu-004","title":"泊秦淮","dynasty":"唐","author":"杜牧","content":["烟笼寒水月笼沙，","夜泊秦淮近酒家。","商女不知亡国恨，","隔江犹唱后庭花。"],"tags":["感怀","七言绝句"],"note":"","appreciation":""},{"id":"tang-dumu-005","title":"秋夕","dynasty":"唐","author":"杜牧","content":["银烛秋光冷画屏，","轻罗小扇扑流萤。","天阶夜色凉如水，","卧看牵牛织女星。"],"tags":["宫怨","七言绝句"],"note":"","appreciation":""},{"id":"tang-dumu-006","title":"寄扬州韩绰判官","dynasty":"唐","author":"杜牧","content":["青山隐隐水迢迢，","秋尽江南草未凋。","二十四桥明月夜，","玉人何处教吹箫。"],"tags":["友情","七言绝句"],"note":"","appreciation":""},{"id":"tang-lihe-001","title":"马诗","dynasty":"唐","author":"李贺","content":["大漠沙如雪，","燕山月似钩。","何当金络脑，","快走踏清秋。"],"tags":["咏物","五言绝句"],"note":"","appreciation":""},{"id":"tang-liuzongyuan-001","title":"江雪","dynasty":"唐","author":"柳宗元","content":["千山鸟飞绝，","万径人踪灭。","孤舟蓑笠翁，","独钓寒江雪。"],"tags":["写景","冬","五言绝句"],"note":"","appreciation":"孤寂清绝的雪景图。"},{"id":"tang-jia dao-001","title":"寻隐者不遇","dynasty":"唐","author":"贾岛","content":["松下问童子，","言师采药去。","只在此山中，","云深不知处。"],"tags":["隐逸","五言绝句"],"note":"","appreciation":""},{"id":"tang-zhangji-001","title":"枫桥夜泊","dynasty":"唐","author":"张继","content":["月落乌啼霜满天，","江枫渔火对愁眠。","姑苏城外寒山寺，","夜半钟声到客船。"],"tags":["羁旅","七言绝句"],"note":"","appreciation":""},{"id":"tang-hanyu-001","title":"早春呈水部张十八员外","dynasty":"唐","author":"韩愈","content":["天街小雨润如酥，","草色遥看近却无。","最是一年春好处，","绝胜烟柳满皇都。"],"tags":["写景","春雨","七言绝句"],"note":"","appreciation":""},{"id":"tang-liuyuxi-001","title":"望洞庭","dynasty":"唐","author":"刘禹锡","content":["湖光秋月两相和，","潭面无风镜未磨。","遥望洞庭山水翠，","白银盘里一青螺。"],"tags":["写景","山水","七言绝句"],"note":"","appreciation":""},{"id":"tang-liuyuxi-002","title":"浪淘沙","dynasty":"唐","author":"刘禹锡","content":["九曲黄河万里沙，","浪淘风簸自天涯。","如今直上银河去，","同到牵牛织女家。"],"tags":["写景","黄河","七言绝句"],"note":"","appreciation":""},{"id":"tang-liuyuxi-003","title":"乌衣巷","dynasty":"唐","author":"刘禹锡","content":["朱雀桥边野草花，","乌衣巷口夕阳斜。","旧时王谢堂前燕，","飞入寻常百姓家。"],"tags":["怀古","七言绝句"],"note":"","appreciation":""},{"id":"tang-weiiyingwu-001","title":"滁州西涧","dynasty":"唐","author":"韦应物","content":["独怜幽草涧边生，","上有黄鹂深树鸣。","春潮带雨晚来急，","野渡无人舟自横。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"tang-cuihao-001","title":"黄鹤楼","dynasty":"唐","author":"崔颢","content":["昔人已乘黄鹤去，","此地空余黄鹤楼。","黄鹤一去不复返，","白云千载空悠悠。","晴川历历汉阳树，","芳草萋萋鹦鹉洲。","日暮乡关何处是？","烟波江上使人愁。"],"tags":["怀古","思乡","七言律诗"],"note":"","appreciation":"李白见之叹“眼前有景道不得”，为唐人七律压卷。"},{"id":"tang-wanghan-001","title":"凉州词","dynasty":"唐","author":"王翰","content":["葡萄美酒夜光杯，","欲饮琵琶马上催。","醉卧沙场君莫笑，","古来征战几人回。"],"tags":["边塞","七言绝句"],"note":"","appreciation":""},{"id":"tang-zhangzhihe-001","title":"渔歌子","dynasty":"唐","author":"张志和","content":["西塞山前白鹭飞，","桃花流水鳜鱼肥。","青箬笠，绿蓑衣，","斜风细雨不须归。"],"tags":["写景","词","田园"],"note":"","appreciation":""},{"id":"tang-lulun-001","title":"塞下曲","dynasty":"唐","author":"卢纶","content":["月黑雁飞高，","单于夜遁逃。","欲将轻骑逐，","大雪满弓刀。"],"tags":["边塞","五言绝句"],"note":"","appreciation":""},{"id":"tang-mengjiao-001","title":"游子吟","dynasty":"唐","author":"孟郊","content":["慈母手中线，","游子身上衣。","临行密密缝，","意恐迟迟归。","谁言寸草心，","报得三春晖。"],"tags":["亲情","五言古诗"],"note":"","appreciation":"歌颂母爱，朴素动人。"},{"id":"tang-chenziang-001","title":"登幽州台歌","dynasty":"唐","author":"陈子昂","content":["前不见古人，","后不见来者。","念天地之悠悠，","独怆然而涕下！"],"tags":["感怀","古诗"],"note":"","appreciation":""},{"id":"tang-hezhizhang-001","title":"咏柳","dynasty":"唐","author":"贺知章","content":["碧玉妆成一树高，","万条垂下绿丝绦。","不知细叶谁裁出，","二月春风似剪刀。"],"tags":["写景","春日","七言绝句"],"note":"","appreciation":""},{"id":"tang-hezhizhang-002","title":"回乡偶书","dynasty":"唐","author":"贺知章","content":["少小离家老大回，","乡音无改鬓毛衰。","儿童相见不相识，","笑问客从何处来。"],"tags":["思乡","七言绝句"],"note":"","appreciation":""},{"id":"tang-zhangjiuling-001","title":"望月怀远","dynasty":"唐","author":"张九龄","content":["海上生明月，","天涯共此时。","情人怨遥夜，","竟夕起相思。","灭烛怜光满，","披衣觉露滋。","不堪盈手赠，","还寝梦佳期。"],"tags":["思乡","月亮","五言律诗"],"note":"","appreciation":"“海上生明月，天涯共此时”为望月怀远之名句。"},{"id":"tang-wangbo-001","title":"送杜少府之任蜀州","dynasty":"唐","author":"王勃","content":["城阙辅三秦，","风烟望五津。","与君离别意，","同是宦游人。","海内存知己，","天涯若比邻。","无为在歧路，","儿女共沾巾。"],"tags":["送别","五言律诗"],"note":"","appreciation":"“海内存知己，天涯若比邻”旷达超迈。"},{"id":"tang-luobinwang-001","title":"咏鹅","dynasty":"唐","author":"骆宾王","content":["鹅，鹅，鹅，","曲项向天歌。","白毛浮绿水，","红掌拨清波。"],"tags":["咏物","五言古诗"],"note":"","appreciation":""},{"id":"tang-lishen-001","title":"悯农","dynasty":"唐","author":"李绅","content":["锄禾日当午，","汗滴禾下土。","谁知盘中餐，","粒粒皆辛苦。"],"tags":["悯农","五言绝句"],"note":"","appreciation":"体察农人辛苦，传诵极广。"},{"id":"tang-lishen-002","title":"悯农","dynasty":"唐","author":"李绅","content":["春种一粒粟，","秋收万颗子。","四海无闲田，","农夫犹饿死。"],"tags":["悯农","五言绝句"],"note":"","appreciation":""},{"id":"tang-hulingneng-001","title":"小儿垂钓","dynasty":"唐","author":"胡令能","content":["蓬头稚子学垂纶，","侧坐莓苔草映身。","路人借问遥招手，","怕得鱼惊不应人。"],"tags":["童趣","七言绝句"],"note":"","appreciation":""},{"id":"tang-zhangxu-001","title":"桃花溪","dynasty":"唐","author":"张旭","content":["隐隐飞桥隔野烟，","石矶西畔问渔船。","桃花尽日随流水，","洞在清溪何处边。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"song-sushi-001","title":"水调歌头·明月几时有","dynasty":"宋","author":"苏轼","content":["明月几时有？","把酒问青天。","不知天上宫阙，","今夕是何年。","我欲乘风归去，","又恐琼楼玉宇，","高处不胜寒。","起舞弄清影，","何似在人间。","转朱阁，低绮户，照无眠。","不应有恨，","何事长向别时圆？","人有悲欢离合，","月有阴晴圆缺，","此事古难全。","但愿人长久，","千里共婵娟。"],"tags":["月亮","中秋","词"],"note":"","appreciation":"“但愿人长久，千里共婵娟”为中秋绝唱。"},{"id":"song-sushi-002","title":"念奴娇·赤壁怀古","dynasty":"宋","author":"苏轼","content":["大江东去，","浪淘尽，","千古风流人物。","故垒西边，","人道是，","三国周郎赤壁。","乱石穿空，","惊涛拍岸，","卷起千堆雪。","江山如画，","一时多少豪杰。","遥想公瑾当年，","小乔初嫁了，","雄姿英发。","羽扇纶巾，","谈笑间，","樯橹灰飞烟灭。","故国神游，","多情应笑我，","早生华发。","人生如梦，","一尊还酹江月。"],"tags":["怀古","词","豪放"],"note":"","appreciation":"豪放词的开山之作，气象磅礴。"},{"id":"song-sushi-003","title":"江城子·乙卯正月二十日夜记梦","dynasty":"宋","author":"苏轼","content":["十年生死两茫茫。","不思量，","自难忘。","千里孤坟，","无处话凄凉。","纵使相逢应不识，","尘满面，","鬓如霜。","夜来幽梦忽还乡。","小轩窗，","正梳妆。","相顾无言，","惟有泪千行。","料得年年肠断处，","明月夜，","短松冈。"],"tags":["悼亡","词"],"note":"","appreciation":""},{"id":"song-sushi-004","title":"江城子·密州出猎","dynasty":"宋","author":"苏轼","content":["老夫聊发少年狂，","左牵黄，","右擎苍。","锦帽貂裘，","千骑卷平冈。","为报倾城随太守，","亲射虎，","看孙郎。","酒酣胸胆尚开张，","鬓微霜，","又何妨！","持节云中，","何日遣冯唐？","会挽雕弓如满月，","西北望，","射天狼。"],"tags":["言志","词","豪放"],"note":"","appreciation":""},{"id":"song-sushi-005","title":"定风波·莫听穿林打叶声","dynasty":"宋","author":"苏轼","content":["莫听穿林打叶声，","何妨吟啸且徐行。","竹杖芒鞋轻胜马，","谁怕？","一蓑烟雨任平生。","料峭春风吹酒醒，","微冷，","山头斜照却相迎。","回首向来萧瑟处，","归去，","也无风雨也无晴。"],"tags":["抒怀","词"],"note":"","appreciation":"“一蓑烟雨任平生”见豁达胸襟。"},{"id":"song-sushi-006","title":"题西林壁","dynasty":"宋","author":"苏轼","content":["横看成岭侧成峰，","远近高低各不同。","不识庐山真面目，","只缘身在此山中。"],"tags":["哲理","七言绝句"],"note":"","appreciation":"“不识庐山真面目”寓当局者迷之理。"},{"id":"song-sushi-007","title":"饮湖上初晴后雨","dynasty":"宋","author":"苏轼","content":["水光潋滟晴方好，","山色空蒙雨亦奇。","欲把西湖比西子，","淡妆浓抹总相宜。"],"tags":["写景","西湖","七言绝句"],"note":"","appreciation":""},{"id":"song-liqingzhao-001","title":"如梦令·昨夜雨疏风骤","dynasty":"宋","author":"李清照","content":["昨夜雨疏风骤，","浓睡不消残酒。","试问卷帘人，","却道海棠依旧。","知否，","知否？","应是绿肥红瘦。"],"tags":["惜春","词"],"note":"","appreciation":"“绿肥红瘦”炼字精妙。"},{"id":"song-liqingzhao-002","title":"如梦令·常记溪亭日暮","dynasty":"宋","author":"李清照","content":["常记溪亭日暮，","沉醉不知归路。","兴尽晚回舟，","误入藕花深处。","争渡，","争渡，","惊起一滩鸥鹭。"],"tags":["记游","词"],"note":"","appreciation":""},{"id":"song-liqingzhao-003","title":"声声慢·寻寻觅觅","dynasty":"宋","author":"李清照","content":["寻寻觅觅，","冷冷清清，","凄凄惨惨戚戚。","乍暖还寒时候，","最难将息。","三杯两盏淡酒，","怎敌他、晚来风急？","雁过也，","正伤心，","却是旧时相识。","满地黄花堆积，","憔悴损，","如今有谁堪摘？","守着窗儿，","独自怎生得黑！","梧桐更兼细雨，","到黄昏、点点滴滴。","这次第，","怎一个愁字了得！"],"tags":["愁绪","词"],"note":"","appreciation":"开篇叠字十四，千古绝调。"},{"id":"song-liqingzhao-004","title":"醉花阴·薄雾浓云愁永昼","dynasty":"宋","author":"李清照","content":["薄雾浓云愁永昼，","瑞脑销金兽。","佳节又重阳，","玉枕纱厨，","半夜凉初透。","东篱把酒黄昏后，","有暗香盈袖。","莫道不销魂，","帘卷西风，","人比黄花瘦。"],"tags":["相思","词"],"note":"","appreciation":""},{"id":"song-liqingzhao-005","title":"一剪梅·红藕香残玉簟秋","dynasty":"宋","author":"李清照","content":["红藕香残玉簟秋。","轻解罗裳，","独上兰舟。","云中谁寄锦书来？","雁字回时，","月满西楼。","花自飘零水自流。","一种相思，","两处闲愁。","此情无计可消除，","才下眉头，","却上心头。"],"tags":["相思","词"],"note":"","appreciation":""},{"id":"song-xinqiji-001","title":"青玉案·元夕","dynasty":"宋","author":"辛弃疾","content":["东风夜放花千树，","更吹落，","星如雨。","宝马雕车香满路。","凤箫声动，","玉壶光转，","一夜鱼龙舞。","蛾儿雪柳黄金缕，","笑语盈盈暗香去。","众里寻他千百度，","蓦然回首，","那人却在，","灯火阑珊处。"],"tags":["元宵","词"],"note":"","appreciation":"“众里寻他千百度”喻苦苦追寻终得之境。"},{"id":"song-xinqiji-002","title":"永遇乐·京口北固亭怀古","dynasty":"宋","author":"辛弃疾","content":["千古江山，","英雄无觅，","孙仲谋处。","舞榭歌台，","风流总被，","雨打风吹去。","斜阳草树，","寻常巷陌，","人道寄奴曾住。","想当年，","金戈铁马，","气吞万里如虎。","元嘉草草，","封狼居胥，","赢得仓皇北顾。","四十三年，","望中犹记，","烽火扬州路。","可堪回首，","佛狸祠下，","一片神鸦社鼓。","凭谁问：","廉颇老矣，","尚能饭否？"],"tags":["怀古","词","豪放"],"note":"","appreciation":""},{"id":"song-xinqiji-003","title":"破阵子·为陈同甫赋壮词以寄之","dynasty":"宋","author":"辛弃疾","content":["醉里挑灯看剑，","梦回吹角连营。","八百里分麾下炙，","五十弦翻塞外声，","沙场秋点兵。","马作的卢飞快，","弓如霹雳弦惊。","了却君王天下事，","赢得生前身后名。","可怜白发生！"],"tags":["言志","词","豪放"],"note":"","appreciation":""},{"id":"song-xinqiji-004","title":"西江月·夜行黄沙道中","dynasty":"宋","author":"辛弃疾","content":["明月别枝惊鹊，","清风半夜鸣蝉。","稻花香里说丰年，","听取蛙声一片。","七八个星天外，","两三点雨山前。","旧时茅店社林边，","路转溪桥忽见。"],"tags":["写景","词","田园"],"note":"","appreciation":""},{"id":"song-xinqiji-005","title":"菩萨蛮·书江西造口壁","dynasty":"宋","author":"辛弃疾","content":["郁孤台下清江水，","中间多少行人泪。","西北望长安，","可怜无数山。","青山遮不住，","毕竟东流去。","江晚正愁余，","山深闻鹧鸪。"],"tags":["忧国","词"],"note":"","appreciation":""},{"id":"song-yuefei-001","title":"满江红·写怀","dynasty":"宋","author":"岳飞","content":["怒发冲冠，","凭栏处、","潇潇雨歇。","抬望眼，","仰天长啸，","壮怀激烈。","三十功名尘与土，","八千里路云和月。","莫等闲、","白了少年头，","空悲切。","靖康耻，","犹未雪。","臣子恨，","何时灭！","驾长车，","踏破贺兰山缺。","壮志饥餐胡虏肉，","笑谈渴饮匈奴血。","待从头、","收拾旧山河，","朝天阙。"],"tags":["言志","词","豪放"],"note":"","appreciation":"忠愤之气，千载下犹凛凛有生气。"},{"id":"song-liuyong-001","title":"雨霖铃·寒蝉凄切","dynasty":"宋","author":"柳永","content":["寒蝉凄切，","对长亭晚，","骤雨初歇。","都门帐饮无绪，","留恋处，","兰舟催发。","执手相看泪眼，","竟无语凝噎。","念去去，","千里烟波，","暮霭沉沉楚天阔。","多情自古伤离别，","更那堪，","冷落清秋节！","今宵酒醒何处？","杨柳岸，","晓风残月。","此去经年，","应是良辰好景虚设。","便纵有千种风情，","更与何人说？"],"tags":["送别","词"],"note":"","appreciation":""},{"id":"song-qinguan-001","title":"鹊桥仙·纤云弄巧","dynasty":"宋","author":"秦观","content":["纤云弄巧，","飞星传恨，","银汉迢迢暗度。","金风玉露一相逢，","便胜却、","人间无数。","柔情似水，","佳期如梦，","忍顾鹊桥归路。","两情若是久长时，","又岂在、","朝朝暮暮。"],"tags":["爱情","词"],"note":"","appreciation":"“两情若是久长时，又岂在朝朝暮暮”翻出新意。"},{"id":"song-yanshu-001","title":"浣溪沙·一曲新词酒一杯","dynasty":"宋","author":"晏殊","content":["一曲新词酒一杯，","去年天气旧亭台。","夕阳西下几时回？","无可奈何花落去，","似曾相识燕归来。","小园香径独徘徊。"],"tags":["感怀","词"],"note":"","appreciation":"“无可奈何花落去”道尽韶华难留之怅。"},{"id":"song-ouyangxiu-001","title":"蝶恋花·庭院深深深几许","dynasty":"宋","author":"欧阳修","content":["庭院深深深几许，","杨柳堆烟，","帘幕无重数。","玉勒雕鞍游冶处，","楼高不见章台路。","雨横风狂三月暮，","门掩黄昏，","无计留春住。","泪眼问花花不语，","乱红飞过秋千去。"],"tags":["闺怨","词"],"note":"","appreciation":""},{"id":"song-fanzhongyan-001","title":"渔家傲·秋思","dynasty":"宋","author":"范仲淹","content":["塞下秋来风景异，","衡阳雁去无留意。","四面边声连角起。","千嶂里，","长烟落日孤城闭。","浊酒一杯家万里，","燕然未勒归无计。","羌管悠悠霜满地。","人不寐，","将军白发征夫泪。"],"tags":["边塞","词"],"note":"","appreciation":""},{"id":"songshi-luyou-001","title":"示儿","dynasty":"宋","author":"陆游","content":["死去元知万事空，","但悲不见九州同。","王师北定中原日，","家祭无忘告乃翁。"],"tags":["爱国","七言绝句"],"note":"","appreciation":""},{"id":"songshi-luyou-002","title":"十一月四日风雨大作","dynasty":"宋","author":"陆游","content":["僵卧孤村不自哀，","尚思为国戍轮台。","夜阑卧听风吹雨，","铁马冰河入梦来。"],"tags":["爱国","七言绝句"],"note":"","appreciation":""},{"id":"songshi-luyou-003","title":"游山西村","dynasty":"宋","author":"陆游","content":["莫笑农家腊酒浑，","丰年留客足鸡豚。","山重水复疑无路，","柳暗花明又一村。","箫鼓追随春社近，","衣冠简朴古风存。","从今若许闲乘月，","拄杖无时夜叩门。"],"tags":["田园","七言律诗"],"note":"","appreciation":"“山重水复疑无路，柳暗花明又一村”喻绝处逢生。"},{"id":"songshi-wanganshi-001","title":"泊船瓜洲","dynasty":"宋","author":"王安石","content":["京口瓜洲一水间，","钟山只隔数重山。","春风又绿江南岸，","明月何时照我还。"],"tags":["思乡","七言绝句"],"note":"","appreciation":"“绿”字炼字典范。"},{"id":"songshi-wanganshi-002","title":"元日","dynasty":"宋","author":"王安石","content":["爆竹声中一岁除，","春风送暖入屠苏。","千门万户曈曈日，","总把新桃换旧符。"],"tags":["节日","七言绝句"],"note":"","appreciation":""},{"id":"songshi-zhuxi-001","title":"观书有感","dynasty":"宋","author":"朱熹","content":["半亩方塘一鉴开，","天光云影共徘徊。","问渠那得清如许？","为有源头活水来。"],"tags":["哲理","七言绝句"],"note":"","appreciation":""},{"id":"songshi-yangwanli-001","title":"小池","dynasty":"宋","author":"杨万里","content":["泉眼无声惜细流，","树阴照水爱晴柔。","小荷才露尖尖角，","早有蜻蜓立上头。"],"tags":["写景","七言绝句"],"note":"","appreciation":""},{"id":"songshi-yangwanli-002","title":"晓出净慈寺送林子方","dynasty":"宋","author":"杨万里","content":["毕竟西湖六月中，","风光不与四时同。","接天莲叶无穷碧，","映日荷花别样红。"],"tags":["写景","西湖","七言绝句"],"note":"","appreciation":""},{"id":"songshi-fanchengda-001","title":"四时田园杂兴","dynasty":"宋","author":"范成大","content":["昼出耘田夜绩麻，","村庄儿女各当家。","童孙未解供耕织，","也傍桑阴学种瓜。"],"tags":["田园","七言绝句"],"note":"","appreciation":""},{"id":"songshi-yeshaoweng-001","title":"游园不值","dynasty":"宋","author":"叶绍翁","content":["应怜屐齿印苍苔，","小扣柴扉久不开。","春色满园关不住，","一枝红杏出墙来。"],"tags":["写景","七言绝句"],"note":"","appreciation":"“春色满园关不住，一枝红杏出墙来”生机盎然。"},{"id":"songshi-wangmian-001","title":"墨梅","dynasty":"宋","author":"王冕","content":["我家洗砚池头树，","朵朵花开淡墨痕。","不要人夸好颜色，","只留清气满乾坤。"],"tags":["咏物","七言绝句"],"note":"","appreciation":""},{"id":"songshi-linsheng-001","title":"题临安邸","dynasty":"宋","author":"林升","content":["山外青山楼外楼，","西湖歌舞几时休？","暖风熏得游人醉，","直把杭州作汴州。"],"tags":["感怀","七言绝句"],"note":"","appreciation":""},{"id":"songshi-wangwan-001","title":"次北固山下","dynasty":"唐","author":"王湾","content":["客路青山外，","行舟绿水前。","潮平两岸阔，","风正一帆悬。","海日生残夜，","江春入旧年。","乡书何处达？","归雁洛阳边。"],"tags":["羁旅","五言律诗"],"note":"王湾为盛唐诗人，此诗虽成于唐，常入选唐诗选本。","appreciation":""},{"id":"shijing-001","title":"关雎","dynasty":"诗经","author":"国风·周南","content":["关关雎鸠，在河之洲。","窈窕淑女，君子好逑。","参差荇菜，左右流之。","窈窕淑女，寤寐求之。","求之不得，寤寐思服。","悠哉悠哉，辗转反侧。","参差荇菜，左右采之。","窈窕淑女，琴瑟友之。","参差荇菜，左右芼之。","窈窕淑女，钟鼓乐之。"],"tags":["爱情","国风"],"note":"","appreciation":""},{"id":"shijing-002","title":"蒹葭","dynasty":"诗经","author":"国风·秦风","content":["蒹葭苍苍，白露为霜。","所谓伊人，在水一方。","溯洄从之，道阻且长。","溯游从之，宛在水中央。","蒹葭萋萋，白露未晞。","所谓伊人，在水之湄。","溯洄从之，道阻且跻。","溯游从之，宛在水中坻。","蒹葭采采，白露未已。","所谓伊人，在水之涘。","溯洄从之，道阻且右。","溯游从之，宛在水中沚。"],"tags":["爱情","国风"],"note":"","appreciation":""},{"id":"shijing-003","title":"采薇","dynasty":"诗经","author":"小雅","content":["采薇采薇，薇亦作止。","曰归曰归，岁亦莫止。","靡室靡家，猃狁之故。","不遑启居，猃狁之故。","昔我往矣，杨柳依依。","今我来思，雨雪霏霏。","行道迟迟，载渴载饥。","我心伤悲，莫知我哀！"],"tags":["战争","小雅"],"note":"","appreciation":"“昔我往矣，杨柳依依；今我来思，雨雪霏霏”为千古写征戍之绝唱。"},{"id":"shijing-004","title":"硕鼠","dynasty":"诗经","author":"国风·魏风","content":["硕鼠硕鼠，无食我黍！","三岁贯女，莫我肯顾。","逝将去女，适彼乐土。","乐土乐土，爰得我所。","硕鼠硕鼠，无食我麦！","三岁贯女，莫我肯德。","逝将去女，适彼乐国。","乐国乐国，爰得我直。","硕鼠硕鼠，无食我苗！","三岁贯女，莫我肯劳。","逝将去女，适彼乐郊。","乐郊乐郊，谁之永号？"],"tags":["讽喻","国风"],"note":"","appreciation":""},{"id":"shijing-005","title":"伐檀","dynasty":"诗经","author":"国风·魏风","content":["坎坎伐檀兮，置之河之干兮。","河水清且涟猗。","不稼不穑，胡取禾三百廛兮？","不狩不猎，胡瞻尔庭有县貆兮？","彼君子兮，不素餐兮！"],"tags":["讽喻","国风"],"note":"","appreciation":""},{"id":"shijing-006","title":"木瓜","dynasty":"诗经","author":"国风·卫风","content":["投我以木瓜，报之以琼琚。","匪报也，永以为好也。","投我以木桃，报之以琼瑶。","匪报也，永以为好也。","投我以木李，报之以琼玖。","匪报也，永以为好也。"],"tags":["友情","国风"],"note":"","appreciation":""},{"id":"shijing-007","title":"静女","dynasty":"诗经","author":"国风·邶风","content":["静女其姝，俟我于城隅。","爱而不见，搔首踟蹰。","静女其娈，贻我彤管。","彤管有炜，说怿女美。","自牧归荑，洵美且异。","匪女之为美，美人之贻。"],"tags":["爱情","国风"],"note":"","appreciation":""},{"id":"shijing-008","title":"子衿","dynasty":"诗经","author":"国风·郑风","content":["青青子衿，悠悠我心。","纵我不往，子宁不嗣音？","青青子佩，悠悠我思。","纵我不往，子宁不来？","挑兮达兮，在城阙兮。","一日不见，如三月兮。"],"tags":["爱情","国风"],"note":"","appreciation":""},{"id":"shijing-009","title":"鹿鸣","dynasty":"诗经","author":"小雅","content":["呦呦鹿鸣，食野之苹。","我有嘉宾，鼓瑟吹笙。","吹笙鼓簧，承筐是将。","人之好我，示我周行。"],"tags":["宴饮","小雅"],"note":"","appreciation":""},{"id":"shijing-010","title":"黍离","dynasty":"诗经","author":"国风·王风","content":["彼黍离离，彼稷之苗。","行迈靡靡，中心摇摇。","知我者，谓我心忧；","不知我者，谓我何求。","悠悠苍天，此何人哉！"],"tags":["忧国","国风"],"note":"","appreciation":""},{"id":"yuan-mazhiyuan-001","title":"天净沙·秋思","dynasty":"元","author":"马致远","content":["枯藤老树昏鸦，","小桥流水人家，","古道西风瘦马。","夕阳西下，","断肠人在天涯。"],"tags":["秋日","羁旅","散曲"],"note":"","appreciation":"寥寥数笔，写尽天涯游子之悲。"},{"id":"yuan-zhangyanghao-001","title":"山坡羊·潼关怀古","dynasty":"元","author":"张养浩","content":["峰峦如聚，","波涛如怒，","山河表里潼关路。","望西都，","意踌躇。","伤心秦汉经行处，","宫阙万间都做了土。","兴，百姓苦；","亡，百姓苦。"],"tags":["怀古","散曲"],"note":"","appreciation":"“兴，百姓苦；亡，百姓苦”为千古沉痛之句。"},{"id":"yuan-baipu-001","title":"天净沙·秋","dynasty":"元","author":"白朴","content":["孤村落日残霞，","轻烟老树寒鸦，","一点飞鸿影下。","青山绿水，","白草红叶黄花。"],"tags":["秋日","写景","散曲"],"note":"","appreciation":""},{"id":"yuan-xuzai-001","title":"凭阑人·江夜","dynasty":"元","author":"张可久","content":["江水澄澄江月明，","江上何人搊玉筝？","隔江和泪听，","满江长叹声。"],"tags":["写景","散曲"],"note":"","appreciation":""},{"id":"other-yuefu-001","title":"江南","dynasty":"其他","author":"汉乐府","content":["江南可采莲，","莲叶何田田。","鱼戏莲叶间。","鱼戏莲叶东，","鱼戏莲叶西，","鱼戏莲叶南，","鱼戏莲叶北。"],"tags":["乐府","写景"],"note":"","appreciation":""},{"id":"other-yuefu-002","title":"长歌行","dynasty":"其他","author":"汉乐府","content":["青青园中葵，","朝露待日晞。","阳春布德泽，","万物生光辉。","常恐秋节至，","焜黄华叶衰。","百川东到海，","何时复西归？","少壮不努力，","老大徒伤悲。"],"tags":["励志","乐府"],"note":"","appreciation":"“少壮不努力，老大徒伤悲”为劝学名句。"},{"id":"other-caocao-001","title":"观沧海","dynasty":"其他","author":"曹操","content":["东临碣石，以观沧海。","水何澹澹，山岛竦峙。","树木丛生，百草丰茂。","秋风萧瑟，洪波涌起。","日月之行，若出其中；","星汉灿烂，若出其里。","幸甚至哉，歌以咏志。"],"tags":["写景","言志","四言"],"note":"","appreciation":""},{"id":"other-caocao-002","title":"龟虽寿","dynasty":"其他","author":"曹操","content":["神龟虽寿，犹有竟时。","腾蛇乘雾，终为土灰。","老骥伏枥，志在千里。","烈士暮年，壮心不已。","盈缩之期，不但在天；","养怡之福，可得永年。","幸甚至哉，歌以咏志。"],"tags":["励志","四言"],"note":"","appreciation":"“老骥伏枥，志在千里”抒老当益壮之志。"},{"id":"other-caozhi-001","title":"七步诗","dynasty":"其他","author":"曹植","content":["煮豆燃豆萁，","豆在釜中泣。","本是同根生，","相煎何太急？"],"tags":["讽喻","五言古诗"],"note":"","appreciation":""},{"id":"other-taoyuanming-001","title":"饮酒·其五","dynasty":"其他","author":"陶渊明","content":["结庐在人境，","而无车马喧。","问君何能尔？","心远地自偏。","采菊东篱下，","悠然见南山。","山气日夕佳，","飞鸟相与还。","此中有真意，","欲辨已忘言。"],"tags":["隐逸","五言古诗"],"note":"","appreciation":"“采菊东篱下，悠然见南山”闲适淡远，田园诗之典范。"},{"id":"other-taoyuanming-002","title":"归园田居·其三","dynasty":"其他","author":"陶渊明","content":["种豆南山下，","草盛豆苗稀。","晨兴理荒秽，","带月荷锄归。","道狭草木长，","夕露沾我衣。","衣沾不足惜，","但使愿无违。"],"tags":["田园","五言古诗"],"note":"","appreciation":""},{"id":"other-changlege-001","title":"敕勒歌","dynasty":"其他","author":"北朝民歌","content":["敕勒川，阴山下。","天似穹庐，笼盖四野。","天苍苍，野茫茫，","风吹草低见牛羊。"],"tags":["民歌","写景"],"note":"","appreciation":"北朝民歌代表作，苍茫壮阔。"},{"id":"other-mulan-001","title":"木兰诗（节选）","dynasty":"其他","author":"北朝民歌","content":["唧唧复唧唧，木兰当户织。","不闻机杼声，惟闻女叹息。","万里赴戎机，关山度若飞。","朔气传金柝，寒光照铁衣。","将军百战死，壮士十年归。","雄兔脚扑朔，雌兔眼迷离；","双兔傍地走，安能辨我是雄雌？"],"tags":["民歌","叙事"],"note":"此为《木兰诗》节选，原诗较长。","appreciation":""},{"id":"other-chuci-001","title":"离骚（节选）","dynasty":"其他","author":"屈原","content":["路漫漫其修远兮，","吾将上下而求索。","长太息以掩涕兮，","哀民生之多艰。","亦余心之所善兮，","虽九死其犹未悔。"],"tags":["楚辞","言志"],"note":"《离骚》为屈原代表作，此为千古名句节选。","appreciation":"“路漫漫其修远兮，吾将上下而求索”为求道不息之宣言。"}]